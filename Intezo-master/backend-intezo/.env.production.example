NODE_ENV=production
PORT=3000

# Public application URLs
FRONTEND_URL=https://web.intezo.online
PUBLIC_WEB_URL=https://web.intezo.online
ENABLE_API_DOCS=false

# Generate with a password manager: at least 32 random characters.
JWT_SECRET=replace-with-a-long-random-secret
AUTH_RATE_LIMIT=30
JSON_BODY_LIMIT=1mb

# Managed PostgreSQL / Supabase / RDS
DB_HOST=replace-with-postgres-host
DB_PORT=5432
DB_NAME=intezo_queue
DB_USER=replace-with-postgres-user
DB_PASSWORD=replace-with-postgres-password
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true
# Optional PEM CA certificate with newlines encoded as \n
DB_CA_CERT=

# Supplied by docker-compose.production.yml
REDIS_URL=redis://redis:6379
REQUIRE_REDIS=true

# Private report storage. Use the EC2 instance role; do not add AWS keys here.
AWS_REGION=ap-south-1
REPORTS_S3_BUCKET=replace-with-private-reports-bucket
REQUIRE_S3_REPORT_STORAGE=true

# Use the timezone in which clinic operating hours are defined.
APP_TIMEZONE=Asia/Karachi

# Email
EMAIL_SERVICE=gmail
EMAIL_USER=replace-with-email
EMAIL_PASS=replace-with-app-password

# Firebase Cloud Messaging
FIREBASE_PROJECT_ID=replace-with-project-id
FIREBASE_CLIENT_EMAIL=replace-with-client-email
FIREBASE_PRIVATE_KEY=replace-with-private-key

# Profile photo storage (recommended for production)
CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret
